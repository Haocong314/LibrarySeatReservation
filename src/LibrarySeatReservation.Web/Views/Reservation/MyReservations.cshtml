@{
    ViewData["Title"] = "我的预约";
}

<div class="user-container">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 style="color: var(--primary); margin:0;">我的预约</h5>
        <a href="@Url.Action("Index", "Seat")" class="btn btn-outline-custom btn-sm">浏览座位</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-custom">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-custom">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">&#128197;</div>
            <p>还没有预约记录</p>
            <a href="@Url.Action("Index", "Seat")" class="btn btn-primary-custom btn-sm mt-2">去预约</a>
        </div>
    }
    else
    {
        @foreach (var res in Model)
        {
            <div class="user-card mb-2">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="fw-bold">@res.SeatNumber <span class="text-muted fw-normal">@res.AreaName</span></div>
                        <div class="text-muted" style="font-size:0.9rem;">
                            @res.ReservationDate.ToString("yyyy-MM-dd") &nbsp; @res.TimeSlot
                        </div>
                        <span class="badge-status mt-1 @(res.Status == "已预约" ? "badge-active" : "badge-cancelled")">
                            @res.Status
                        </span>
                    </div>
                    @if (res.Status == "已预约")
                    {
                        <form method="post" asp-action="Cancel" class="ms-2" onsubmit="return confirm('确定要取消这个预约吗？');">
                            <input type="hidden" name="id" value="@res.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">取消</button>
                        </form>
                    }
                </div>
            </div>
        }
    }

    <div class="bottom-safe"></div>
</div>