<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 图书馆座位预约</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        @if (Context.Session.GetInt32("AdminId") != null)
        {
            <!-- 管理端导航 -->
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
                <div class="container-fluid">
                    <a class="navbar-brand" href="@Url.Action("Reservations", "AdminManage")">图书馆管理后台</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="adminNav">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Reservations", "AdminManage")">预约管理</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Seats", "AdminManage")">座位管理</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Stats", "AdminManage")">统计</a>
                            </li>
                        </ul>
                        <span class="navbar-text me-3">管理员：@Context.Session.GetString("AdminUsername")</span>
                        <a class="btn btn-outline-light btn-sm" href="@Url.Action("Logout", "Admin")">退出</a>
                    </div>
                </div>
            </nav>
        }
        else
        {
            <!-- 用户端导航 -->
            <nav class="navbar navbar-expand-lg" style="background-color: #2c5f8a;">
                <div class="container">
                    <a class="navbar-brand text-white fw-bold" href="@Url.Action("Index", "Home")">
                        图书馆座位预约
                    </a>
                    <div class="ms-auto">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <a class="btn btn-outline-light btn-sm me-2" href="@Url.Action("Index", "Seat")">座位列表</a>
                            <a class="btn btn-outline-light btn-sm me-2" href="@Url.Action("MyReservations", "Reservation")">我的预约</a>
                            <a class="btn btn-light btn-sm" href="@Url.Action("Logout", "Home")">切换账号</a>
                        }
                    </div>
                </div>
            </nav>
        }
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-center text-muted py-3 mt-4 border-top">
        <small>&copy; 2026 图书馆座位预约系统 - 课堂项目</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
