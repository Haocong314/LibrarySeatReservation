@{
    ViewData["Title"] = "座位列表";
}

<div class="user-container">
    <div class="user-card">
        <h5 class="mb-3" style="color: var(--primary);">选择座位</h5>
        <form method="get" class="mb-3">
            <select name="areaId" class="form-select" style="border-radius: var(--btn-radius);" onchange="this.form.submit()">
                <option value="">全部区域</option>
                @if (ViewBag.Areas != null)
                {
                    foreach (var area in ViewBag.Areas)
                    {
                        var selected = (int?)ViewBag.SelectedAreaId == area.Id ? "selected" : "";
                        <option value="@area.Id" selected="@selected">@area.Name（@area.Floor）</option>
                    }
                }
            </select>
        </form>
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">&#128218;</div>
            <p>当前没有可用座位</p>
        </div>
    }
    else
    {
        @foreach (var seat in Model)
        {
            <div class="user-card seat-card">
                <div>
                    <span class="seat-number-badge">@seat.SeatNumber</span>
                    <span class="ms-2 text-muted">@seat.AreaName @seat.Floor</span>
                    <span class="ms-2 badge-status @(seat.Status == "Available" ? "badge-available" : "badge-disabled")">
                        @(seat.Status == "Available" ? "可用" : "停用")
                    </span>
                </div>
                <a href="@Url.Action("Detail", "Seat", new { id = seat.Id })"
                   class="btn @(seat.Status == "Available" ? "btn-primary-custom" : "btn-outline-custom") btn-sm">
                    @(seat.Status == "Available" ? "查看" : "详情")
                </a>
            </div>
        }
    }

    <div class="bottom-safe"></div>
</div>
